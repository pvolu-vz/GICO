# GICO-Veza OAA Integration Configuration
# Copy this file to .env and fill in your values.

# Veza Configuration
VEZA_URL=your-company.veza.com
VEZA_API_KEY=your_veza_api_key_here

# GICO Data Source — path to directory containing GICO export files
# This can be a local path or a mounted SMB/CIFS share
GICO_DATA_DIR=/path/to/gico/exports

# OAA Provider Settings (optional overrides)
# PROVIDER_NAME=GICO
# DATASOURCE_NAME=GICO
